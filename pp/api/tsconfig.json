{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    
    /* Modules */
    "rootDir": "../",
    "outDir": "./dist",
    "baseUrl": ".",
	"paths": {
      "@models/*": ["../_model/*"]
	},
    
    /* JavaScript Support */
    "allowJs": true,
    "checkJs": false,
    
    /* Emit */
    "removeComments": true,
    "noEmitOnError": true,
    
    /* Interop Constraints */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    
    /* Type Checking */
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "_model/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}